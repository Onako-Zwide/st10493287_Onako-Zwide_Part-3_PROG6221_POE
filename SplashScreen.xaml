<Window x:Class="CyberSecurityChatbot_PART_2.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uniqua Safespace"
        Height="500"
        Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0A192F"
        AllowsTransparency="True">

    <Grid>

        <!-- Glow border -->
        <Border CornerRadius="25"
                BorderBrush="Magenta"
                BorderThickness="2"
                Margin="10">

            <Grid>

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <!-- Butterfly -->
                    <TextBlock Text="🦋"
                               FontSize="70"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- App Name -->
                    <TextBlock Text="UNIQUA SAFESPACE"
                               Foreground="Magenta"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <!-- Logo/Slogan -->
                    <TextBlock Text="A SAFESPACE for Smarter Cyber Choices"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>

                    <!-- Loading -->
                    <TextBlock Text="Loading..."
                               Foreground="Cyan"
                               FontSize="14"
                               Margin="0,30,0,0"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Window>